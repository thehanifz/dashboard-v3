# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=production
ROOT_PATH=/api
BACKEND_CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet RAW (data utama)
SHEET_NAME=RAW

# Sheet Opsi (master status dropdown)
STATUS_SHEET_NAME=Opsi
STATUS_COL_PRIMARY=Status Pekerjaan
STATUS_COL_DETAIL=Detail Progres

# ── Teskom ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
IMG_QUALITY=85
IMG_WIDTH_OT=70
IMG_WIDTH_SINGLE=140
IMG_WIDTH_BERT=160
TMP_DIR=tmp

TEMPLATE_CC_TDM_T=templates/docx/cc_tdm_t.docx
TEMPLATE_CC_TDM_OT=templates/docx/cc_tdm_ot.docx
TEMPLATE_CC_IP_T=templates/docx/cc_ip_t.docx
TEMPLATE_CC_IP_OT=templates/docx/cc_ip_ot.docx
TEMPLATE_DF_T=templates/docx/df_t.docx
TEMPLATE_DF_OT=templates/docx/df_ot.docx
