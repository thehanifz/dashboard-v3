# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=production

# ── CORS — sesuaikan dengan domain kamu ──────────────────────────────────────
BACKEND_CORS_ORIGINS=https://yourdomain.com

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=PLN
STATUS_SHEET_NAME=Opsi
STATUS_COL_PRIMARY=Status Pekerjaan
STATUS_COL_DETAIL=Detail Progres

# ── Nama kolom di GSheet untuk filter per role ────────────────────────────────
PTL_COL_TERMINATING=PTL TERMINATING
PTL_COL_ORIGINATING=PTL ORIGINATING
MITRA_COLUMN_NAME=MITRA TERMINATING

# ── Kolom editable per role ───────────────────────────────────────────────────
PTL_EDITABLE_COLUMNS=STATUS,DETAIL,KETERANGAN
MITRA_EDITABLE_WHITELIST=VALIDASI_MITRA,KETERANGAN_MITRA,STATUS_MITRA

# ── Teskom ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
IMG_QUALITY=85
TMP_DIR=tmp

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://db_user:db_password@localhost:5433/db_name
DB_URL_SYNC=postgresql+psycopg2://db_user:db_password@localhost:5433/db_name

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate SECRET_KEY baru dengan:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Superuser (tidak disimpan di DB, dikonfigurasi di sini saja) ──────────────
# Buat hash password dengan:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('PASSWORD_KAMU'))"
SUPERUSER_USERNAME=superadmin
SUPERUSER_PASSWORD_HASH=your_bcrypt_hash_here
